{
  "expo": {
    "name": "temp-expo",
    "slug": "temp-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tempexpo",
    "userInterfaceStyle": "automatic",
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
